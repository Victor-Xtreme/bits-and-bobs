{
  "name": "reposense",
  "displayName": "RepoSense",
  "description": "Analyze workspace repositories and get health scores",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/bits-and-bobs-deployment.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:reposense-sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reposense.refresh",
        "title": "Refresh Analysis",
        "icon": "$(refresh)"
      },
      {
        "command": "reposense.openInBrowser",
        "title": "RepoSense: Open in Browser",
        "icon": "$(globe)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reposense-sidebar-view",
          "title": "RepoSense",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "reposense-sidebar-view": [
        {
          "type": "webview",
          "id": "reposense-sidebar",
          "name": "RepoSense",
          "icon": "media/icon.svg",
          "contextualTitle": "RepoSense"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "reposense.refresh",
          "when": "view == reposense-sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "RepoSense",
      "properties": {
        "reposense.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the RepoSense backend API server"
        },
        "reposense.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout in milliseconds"
        },
        "reposense.pollingIntervalMs": {
          "type": "number",
          "default": 2000,
          "description": "How often to poll for job results (milliseconds)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@types/node-fetch": "^2.6.2",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3"
  ,
    "vsce": "^2.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}