{
  "name": "reposense",
  "displayName": "RepoSense",
  "description": "Analyze workspace repositories and get health scores",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:reposense-sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reposense-sidebar-view",
          "title": "RepoSense",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "reposense-sidebar-view": [
        {
          "type": "webview",
          "id": "reposense-sidebar",
          "name": "RepoSense",
          "icon": "media/icon.svg",
          "contextualTitle": "RepoSense"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@types/node-fetch": "^2.6.2",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}