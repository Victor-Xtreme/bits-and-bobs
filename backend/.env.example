# WatsonX Orchestrate Configuration
ORCHESTRATE_API_KEY=your-orchestrate-api-key-here
ORCHESTRATE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com
ORCHESTRATE_INSTANCE_ID=your-instance-id-here
ORCHESTRATE_ENVIRONMENT_ID=your-environment-id-here
ORCHESTRATE_AGENT_ARCHITECT_ID=your-architect-agent-id-here
ORCHESTRATE_AGENT_REVIEWER_ID=your-reviewer-agent-id-here
ORCHESTRATE_AGENT_DOCUMENTER_ID=your-documenter-agent-id-here
ORCHESTRATE_AGENT_HARDENER_ID=your-hardener-agent-id-here

# Optional: Orchestrate timeout in seconds (default: 120)
ORCHESTRATE_TIMEOUT=120

# Optional: Orchestrate model ID
ORCHESTRATE_MODEL_ID=gpt-oss-120b

# WatsonX.ai Configuration
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Optional: WatsonX API URL (defaults to US South region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional: WatsonX model ID
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Optional: API timeout in seconds (default: 120)
WATSONX_TIMEOUT=120

# Optional: Analysis timeout in seconds (default: 600)
ANALYSIS_TIMEOUT=600

# File extensions to parse (py=Python, js=JavaScript, ts=TypeScript)
SUPPORTED_LANGUAGES=py,js,ts,java,go,rs

# Optional: Logging level (default: INFO)
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,vscode-webview://,http://localhost:*
