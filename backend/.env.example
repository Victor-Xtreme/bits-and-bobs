# =============================================================================
# WatsonX Orchestrate Configuration (P2 — required for the 4 AI agents)
# =============================================================================

# Your Orchestrate API key
ORCHESTRATE_API_KEY=your-orchestrate-api-key-here

# Orchestrate base URL
ORCHESTRATE_URL=https://us-south.watson-orchestrate.cloud.ibm.com

# Agent IDs — get these from your watsonx Orchestrate workspace
ORCHESTRATE_AGENT_ARCHITECT_ID=your-architect-agent-id
ORCHESTRATE_AGENT_REVIEWER_ID=your-reviewer-agent-id
ORCHESTRATE_AGENT_DOCUMENTER_ID=your-documenter-agent-id
ORCHESTRATE_AGENT_HARDENER_ID=your-hardener-agent-id

# Optional: timeout in seconds (default: 120)
# ORCHESTRATE_TIMEOUT=120

# Optional: model ID used by the agents (default: granite-3-8b-instruct)
# ORCHESTRATE_MODEL_ID=granite-3-8b-instruct

# =============================================================================
# WatsonX.ai Configuration (P3 — required for health scoring)
# =============================================================================

# Your IBM Cloud API key
WATSONX_API_KEY=your-watsonx-api-key-here

# Your watsonx.ai project ID
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# Optional: API URL (default: US South)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional: model ID (default: granite-3-8b-instruct)
# WATSONX_MODEL_ID=granite-3-8b-instruct

# Optional: timeout in seconds (default: 120)
# WATSONX_TIMEOUT=120

# =============================================================================
# General Settings (optional — defaults shown)
# =============================================================================

# ANALYSIS_TIMEOUT=600
# MAX_FILE_SIZE_MB=10
# MAX_FILES_PER_ANALYSIS=1000
# SUPPORTED_LANGUAGES=py,js,ts,java,go,rs
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# JOB_RETENTION_HOURS=24
# MAX_CONCURRENT_JOBS=10
# LOG_LEVEL=INFO
